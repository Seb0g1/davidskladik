# Единый стиль перевода строк, чтобы Windows + git не помечал файлы как M
* text=auto eol=lf

# Скрипты PowerShell всегда CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Бинарники не трогать
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.pdf binary
*.zip binary
