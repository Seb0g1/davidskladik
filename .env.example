PM_DB_HOST=
PM_DB_PORT=
PM_DB_USER=
PM_DB_PASSWORD=replace-with-password
PM_DB_NAME=
PORT=3000
APP_USER=admin
APP_PASSWORD=replace-with-strong-password
# В production (NODE_ENV=production) обязателен уникальный секрет, не «dev-secret».
APP_SESSION_SECRET=replace-with-long-random-secret
# NODE_ENV=production
AUTO_SYNC_MINUTES=15
# Пороги для авто-отправки цен в цикле AUTO_SYNC_MINUTES (0 = отправлять каждое реальное изменение).
# AUTO_PRICE_MIN_DIFF_RUB=0
# AUTO_PRICE_MIN_DIFF_PCT=0
# При отсутствии активного поставщика (но при наличии подвязки) отправлять stock=0 в маркетплейсы.
# AUTO_ZERO_STOCK_ON_NO_SUPPLIER=true
# При отсутствии любых подвязок отправлять товар в автоархив маркетплейса.
# AUTO_ARCHIVE_ON_NO_LINKS=false
# Авто-восстановление: если поставщик вернулся, снимаем stock=0/архив и возвращаем карточку в работу.
# AUTO_RESTORE_ON_SUPPLIER_RETURN=true
# Приоритетная очередь задач через Redis/BullMQ (автоцены, stock=0, автоархив, ретраи).
# BULLMQ_ENABLED=false
# REDIS_URL=redis://127.0.0.1:6379
DAILY_SYNC_ENABLED=true
DAILY_SYNC_TIME=11:00
PUBLIC_BASE_URL=http://localhost:3000

# За reverse proxy (nginx): число доверенных хопов для X-Forwarded-For (часто 1).
# TRUST_PROXY_HOPS=1

# Загрузки изображений в public/uploads/images
# UPLOAD_MAX_FILES_PER_SESSION=200
# UPLOAD_RETENTION_DAYS=14
# UPLOAD_MAX_DISK_MB=800

# AI-генерация изображений для карточек Ozon
# Вариант A — ключ на этом сервере (может не работать из РФ из‑за unsupported_country_region_territory):
OPENAI_API_KEY=replace-with-openai-api-key
# Неофициальный OpenAI-совместимый API (например AITunnel images/edits): базовый URL с /v1
# OPENAI_BASE_URL=https://api.aitunnel.ru/v1
# Для Gemini/Flux через AITunnel — JSON как в их доке (aspect_ratio, image_size и т.д.):
# OPENAI_IMAGE_CONFIG={"aspect_ratio":"16:9","image_size":"2K"}
# Вариант B — relay на VPS вне ограниченного региона (см. scripts/openai-relay-server.cjs):
# OPENAI_RELAY_URL=https://your-relay.example.com/v1/openai-image-edit
# OPENAI_RELAY_SECRET=replace-with-long-random-secret
# OPENAI_RELAY_TIMEOUT_MS=180000
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_SIZE=1024x1024
# Итоговый файл на диске (после API): квадрат 1000×1000, без изменения запроса к провайдеру. 0 = не менять размер.
# OZON_AI_IMAGE_TARGET_PX=1000
# OPENAI_IMAGE_QUALITY=auto
# OPENAI_IMAGE_FORMAT=png
# Ozon AI prompt supports {productName}
# OZON_AI_IMAGE_PROMPT=Сгенерируй продающее изображение для карточки товара на Ozon. Используй название товара: "{productName}".

# Логи: в production уже JSON-строки; для разработки можно включить явно: LOG_JSON=true
OZON_CLIENT_ID=replace-with-client-id
OZON_API_KEY=replace-with-api-key
DEFAULT_USD_RATE=95
DEFAULT_OZON_MARKUP=1.70
DEFAULT_YANDEX_MARKUP=1.60
YANDEX_SHOPS_JSON=[{"id":"ym-1","name":"Shop 1","businessId":123,"apiKey":"replace"}]
