PM_DB_HOST=
PM_DB_PORT=
PM_DB_USER=
PM_DB_PASSWORD=replace-with-password
PM_DB_NAME=
PORT=3000
APP_USER=admin
APP_PASSWORD=replace-with-strong-password
# В production (NODE_ENV=production) обязателен уникальный секрет, не «dev-secret».
APP_SESSION_SECRET=replace-with-long-random-secret
# NODE_ENV=production
AUTO_SYNC_MINUTES=15
# Пороги для авто-отправки цен в цикле AUTO_SYNC_MINUTES (0 = отправлять каждое реальное изменение).
# AUTO_PRICE_MIN_DIFF_RUB=0
# AUTO_PRICE_MIN_DIFF_PCT=0
# При отсутствии активного поставщика (но при наличии подвязки) отправлять stock=0 в маркетплейсы.
# AUTO_ZERO_STOCK_ON_NO_SUPPLIER=true
# При отсутствии любых подвязок отправлять товар в автоархив маркетплейса.
# AUTO_ARCHIVE_ON_NO_LINKS=false
DAILY_SYNC_ENABLED=true
DAILY_SYNC_TIME=11:00
PUBLIC_BASE_URL=http://localhost:3000

# За reverse proxy (nginx): число доверенных хопов для X-Forwarded-For (часто 1).
# TRUST_PROXY_HOPS=1

# Загрузки изображений в public/uploads/images
# UPLOAD_MAX_FILES_PER_SESSION=200
# UPLOAD_RETENTION_DAYS=14
# UPLOAD_MAX_DISK_MB=800

# Логи: в production уже JSON-строки; для разработки можно включить явно: LOG_JSON=true
OZON_CLIENT_ID=replace-with-client-id
OZON_API_KEY=replace-with-api-key
DEFAULT_USD_RATE=95
DEFAULT_OZON_MARKUP=1.70
DEFAULT_YANDEX_MARKUP=1.60
YANDEX_SHOPS_JSON=[{"id":"ym-1","name":"Shop 1","businessId":123,"apiKey":"replace"}]
